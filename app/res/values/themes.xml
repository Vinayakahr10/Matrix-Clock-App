<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.DotMatrixApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Status bar and Navigation bar will be handled by enableEdgeToEdge() in Activity -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Screen theme (Android 12+) -->
    <style name="Theme.DotMatrixApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F8F9FA</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.DotMatrixApp</item>
    </style>
</resources>
